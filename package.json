{
	"name": "take2",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"data:fetch": "node scripts/fetch-rfc-data.js",
		"data:summaries": "node scripts/generate-summaries.js",
		"data:all": "npm run data:fetch && npm run data:summaries"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"svelte": "^5.51.0",
		"svelte-check": "^4.3.6",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.78.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@tailwindcss/vite": "^4.2.0",
		"@types/cytoscape": "^3.21.9",
		"cytoscape": "^3.33.1",
		"jsonrepair": "^3.13.2",
		"tailwindcss": "^4.2.0",
		"xml2js": "^0.6.2"
	}
}
